import asyncio
import aiohttp
from tqdm.asyncio import tqdm
from certara_secret import oauth2_token, envUrl, cert_verify

# Constants
API_URL = envUrl + "/layar/gpt/retreival/generateVectors"
BATCH_SIZE = 50  # Adjust based on API limits
CONCURRENT_REQUESTS = 10 # Limits how many batches run at once

async def fetch_embeddings(session, semaphore, batch_texts):
    """Sends a single batch of texts to the API."""
    headers = {"Authorization": f"Bearer {oauth2_token}", "Accept": "Application/json"}
    payload = {"inputText": batch_texts, "embedder": "multi-qa-MiniLM-L6-cos-vl"}
    
    async with semaphore:
        try:
            async with session.post(API_URL, json=payload, headers=headers, ssl=cert_verify) as resp:
                if resp.status == 200:
                    result = await resp.json()
                    # Extract text and embeddings
                    return [(item['text'], item['embeddings']) for item in result['data']]
                else:
                    return None
        except Exception as e:
            return None

async def run_pipeline(text_list):
    """Manages batches, concurrency, and progress bar."""
    semaphore = asyncio.Semaphore(CONCURRENT_REQUESTS)
    batches = [text_list[i:i + BATCH_SIZE] for i in range(0, len(text_list), BATCH_SIZE)]
    
    async with aiohttp.ClientSession() as session:
        tasks = [fetch_embeddings(session, semaphore, b) for b in batches]
        
        # tqdm.gather provides the progress bar
        results = await tqdm.gather(*tasks, desc="Embedding Progress")
        
    # Flatten results and filter out errors
    flattened = [item for sublist in results if sublist for item in sublist]
    return flattened

