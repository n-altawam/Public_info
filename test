import asyncio
import httpx
import json
import os
import pandas as pd
from tqdm.notebook import tqdm
from certara_secret import oauth2_token, envUrl, cert_verify

# SSL Configuration
os.environ["SSL_CERT_FILE"] = cert_verify
os.environ["REQUEST_CA_BUNDLE"] = cert_verify

async def process_batch(client, semaphore, batch, url, token):
    """Internal helper to send a single batch request."""
    async with semaphore:
        payload = {"inputText": batch, "embedder": "multi-qa-MiniLM·l6-cos-vl"}
        try:
            response = await client.post(
                url, 
                json=payload, 
                headers={"Authorization": f"Bearer {token}", "Accept": "Application/json"},
                timeout=120.0
            )
            if response.status_code == 200:
                return response.json()
            else:
                return {"error": f"Status {response.status_code}: {response.text}"}
        except Exception as e:
            return {"error": str(e)}

async def get_embeddings_df(texts, output_file="embeddings_cache.jsonl", batch_size=100, max_workers=32):
    """
    Main function: Resumes progress from file, processes embeddings in 
    parallel, and returns a flattened Pandas DataFrame.
    """
    # 1. Check for existing progress
    completed_batches = 0
    if os.path.exists(output_file):
        with open(output_file, "r") as f:
            completed_batches = sum(1 for _ in f)
    
    all_batches = [texts[i : i + batch_size] for i in range(0, len(texts), batch_size)]
    remaining_batches = all_batches[completed_batches:]
    
    # 2. Process remaining batches if any
    if remaining_batches:
        limits = httpx.Limits(max_connections=max_workers, max_keepalive_connections=10)
        semaphore = asyncio.Semaphore(max_workers)
        
        async with httpx.AsyncClient(verify=cert_verify, limits=limits) as client:
            tasks = [process_batch(client, semaphore, b, envUrl, oauth2_token) for b in remaining_batches]
            
            with open(output_file, "a") as f:
                pbar = tqdm(asyncio.as_completed(tasks), total=len(all_batches), 
                            initial=completed_batches, desc="Embedding Progress")
                for coro in pbar:
                    result = await coro
                    f.write(json.dumps(result) + "\n")
                    f.flush()

    # 3. Load from file and flatten into a final DataFrame
    all_records = []
    with open(output_file, "r") as f:
        for line in f:
            batch_data = json.loads(line)
            if "data" in batch_data:
                all_records.extend(batch_data["data"])
    
    return pd.DataFrame(all_records)

