def show_l1_groups(linkage_matrix, labels_127, threshold):
    groups = fcluster(linkage_matrix, t=threshold, criterion='distance')
    n_groups = len(set(groups))
    print(f"\nThreshold {threshold} → {n_groups} L1 groups")
    print("=" * 60)
    
    for g in sorted(set(groups)):
        members = [labels_127[i] for i, grp in enumerate(groups) if grp == g]
        print(f"\nGroup {g} ({len(members)} L2 clusters):")
        for m in sorted(members):
            print(f"  - {m}")

show_l1_groups(linkage_matrix, labels_127, threshold=1.0)
show_l1_groups(linkage_matrix, labels_127, threshold=0.9)
