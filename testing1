import pandas as pd
import numpy as np
import pickle

# Build the final taxonomy artifact
# One row per cluster — label, centroid, size, mean confidence
cluster_summary = (
    results_127[results_127['assigned_label'] != 'unclassified']
    .groupby('assigned_label')
    .agg(
        member_count=('topic', 'count'),
        mean_confidence=('confidence', 'mean'),
        median_confidence=('confidence', 'median'),
    )
    .round(3)
    .reset_index()
)

# Merge in centroids
taxonomy = cluster_summary.merge(
    centroids_127[['cluster_label', 'centroid']],
    left_on='assigned_label',
    right_on='cluster_label',
    how='left'
).drop(columns='cluster_label')

# Rename for clarity
taxonomy = taxonomy.rename(columns={'assigned_label': 'cluster_label'})

# Confirm nothing is missing
assert taxonomy['centroid'].isna().sum() == 0, "Missing centroids detected"
assert len(taxonomy) == 127, f"Expected 127 clusters, got {len(taxonomy)}"

print(f"Taxonomy artifact: {len(taxonomy)} clusters")
print(f"Columns: {taxonomy.columns.tolist()}")
print(f"\nSample:")
print(taxonomy[['cluster_label', 'member_count', 
                 'mean_confidence']].head(10).to_string(index=False))

# Save
taxonomy.to_parquet('final_taxonomy_127.parquet')

# Also save centroids separately as a lightweight lookup
with open('final_centroids_127.pkl', 'wb') as f:
    pickle.dump(taxonomy[['cluster_label', 'centroid']], f)

print("\nSaved: final_taxonomy_127.parquet")
print("Saved: final_centroids_127.pkl")
