def review_cluster(label, cluster_df_clean, results_127, n=15):
    print(f"\n{'='*60}")
    print(f"Cluster: {label}")
    
    # Confidence distribution
    cluster_results = results_127[results_127['assigned_label'] == label]
    print(f"Count: {len(cluster_results)}")
    print(f"Confidence distribution:")
    print(f"  Above 0.80: {(cluster_results['confidence'] > 0.80).mean():.1%}")
    print(f"  0.60-0.80:  {((cluster_results['confidence'] >= 0.60) & (cluster_results['confidence'] <= 0.80)).mean():.1%}")
    print(f"  Below 0.60: {(cluster_results['confidence'] < 0.60).mean():.1%}")
    
    # High confidence strings - what belongs here
    print(f"\nHigh confidence strings (top 10):")
    top = cluster_results.nlargest(10, 'confidence')[['topic', 'confidence']]
    for _, row in top.iterrows():
        print(f"  {row['confidence']:.3f} — {row['topic']}")
    
    # Low confidence strings - what doesnt belong
    print(f"\nLow confidence strings (bottom 10):")
    bottom = cluster_results.nsmallest(10, 'confidence')[['topic', 'confidence']]
    for _, row in bottom.iterrows():
        print(f"  {row['confidence']:.3f} — {row['topic']}")

# Start with weakest cluster
review_cluster('Enrollment Application Status Processing', 
               cluster_df_clean, results_127)
