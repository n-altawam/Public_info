import os
import asyncio
import httpx
import pandas as pd
from tqdm.asyncio import tqdm
from certara_secret import oauth2_token, envUrl, cert_verify

# Env vars
os.environ["SSL_CERT_FILE"] = cert_verify
os.environ["REQUEST_CA_BUNDLE"] = cert_verify

def get_api_service_url():
    return envUrl + "/layar/gpt/retreival/generateVectors"

def auth_token():
    return oauth2_token

# 1. Preprocessing Function
def preprocess_data(df, text_col='text'):
    """Drops duplicates, keeps counts, and returns unique texts."""
    df_clean = df.groupby(text_col).size().reset_index(name='duplicate_count')
    unique_texts = df_clean[text_col].tolist()
    return df_clean, unique_texts

# 2. Async API Call for a Single Batch
async def fetch_batch(batch, client, api_service_url, api_key, sem):
    """Fetches embeddings for a single batch of texts, limited by a semaphore."""
    async with sem:  # Limits concurrent requests to avoid overloading the API
        cmd = {
            "inputText": batch,
            "embedder": "multi-qa-MiniLM-L6-cos-vl"
        }
        try:
            response = await client.post(
                api_service_url, 
                json=cmd,
                headers={"Authorization": f"Bearer {api_key}", "Accept": "application/json"}
            )
            response.raise_for_status() # Automatically raise exception for 4xx/5xx errors
            
            data = response.json().get('data', [])
            # Extract text and embeddings to match them up cleanly
            return [{"text": item['text'], "embeddings": item['embeddings']} for item in data]
            
        except Exception as e:
            print(f"Error on batch: {e}")
            return [] # Return empty list on failure so the pipeline doesn't crash entirely

# 3. Main Async Pipeline
async def run_embedding_pipeline(texts, batch_size=100, max_concurrent=10):
    api_service_url = get_api_service_url()
    api_key = auth_token()
    
    # Chunk the ~200k strings into manageable batches
    batches = [texts[i:i + batch_size] for i in range(0, len(texts), batch_size)]
    
    # Semaphore to limit how many API calls happen at the exact same time
    sem = asyncio.Semaphore(max_concurrent)
    
    # Httpx AsyncClient replaces requests
    async with httpx.AsyncClient(verify=cert_verify, timeout=60.0) as client:
        tasks = [
            fetch_batch(batch, client, api_service_url, api_key, sem) 
            for batch in batches
        ]
        
        # tqdm wrapper for asyncio to show progress bar
        results = await tqdm.gather(*tasks, desc="Fetching Embeddings")
        
    # Flatten the list of lists into a single list of dictionaries
    flattened_results = [item for sublist in results for item in sublist]
    return flattened_results






