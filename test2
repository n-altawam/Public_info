import asyncio
import aiohttp
import pandas as pd
import json
import os
import ssl
import time
from tqdm.asyncio import tqdm
from certara_secret import oauth2_token, envUrl, cert_verify

# Configuration
API_URL = f"{envUrl}/layar/gpt/retreival/generateVectors"
HEADERS = {"Authorization": f"Bearer {oauth2_token}", "Accept": "Application/json"}
MAX_WORKERS = 32
BATCH_SIZE = 50  # Adjust based on server limits
OUTPUT_FILE = "embeddings_checkpoint.jsonl"

# SSL Setup
os.environ["SSL_CERT_FILE"] = cert_verify
os.environ["REQUEST_CA_BUNDLE"] = cert_verify

# Create an SSLContext that trusts the provided CA bundle (safer than disabling verification)
ssl_context = ssl.create_default_context(cafile=cert_verify)

async def process_batch(session, batch, semaphore, max_retries: int = 3, base_backoff: float = 1.0):
    """Sends a single batch of strings to the API with retries and basic validation.

    Returns list of (text, embedding) on success, or None on permanent failure.
    """
    payload = {"inputText": batch, "embedder": "multi-qa-MiniLM-l6-cos-v1"}
    attempt = 0
    async with semaphore:
        while attempt < max_retries:
            try:
                async with session.post(API_URL, json=payload, headers=HEADERS) as resp:
                    status = resp.status
                    text = await resp.text()
                    if status == 200:
                        data = json.loads(text) if text else {}
                        embeddings = data.get("data", [])
                        # Basic check: number of embeddings should match inputs
                        if len(embeddings) != len(batch):
                            print(f"Warning: returned {len(embeddings)} embeddings for {len(batch)} inputs")
                        return list(zip(batch, embeddings))
                    else:
                        print(f"Error {status}: {text}")
                        # treat as transient for retry unless client error
                        if 400 <= status < 500:
                            return None
            except Exception as e:
                print(f"Request attempt {attempt+1} failed: {e}")

            # Exponential backoff before retrying
            attempt += 1
            await asyncio.sleep(base_backoff * (2 ** (attempt - 1)))

        # All retries exhausted
        print(f"Batch failed after {max_retries} attempts")
        return None

async def run_pipeline(text_list):
    # 1. Load progress to resume
    processed_texts = set()
    if os.path.exists(OUTPUT_FILE):
        with open(OUTPUT_FILE, "r") as f:
            for line in f:
                try:
                    processed_texts.add(json.loads(line)["text"])
                except Exception:
                    # skip malformed lines
                    continue

    # 2. Filter out already processed strings
    remaining_texts = [t for t in text_list if t not in processed_texts]
    batches = [remaining_texts[i:i + BATCH_SIZE] for i in range(0, len(remaining_texts), BATCH_SIZE)]
    
    semaphore = asyncio.Semaphore(MAX_WORKERS)

    # aiohttp client with connection limits, timeout and the SSL context
    timeout = aiohttp.ClientTimeout(total=120)
    connector = aiohttp.TCPConnector(limit=MAX_WORKERS, ssl=ssl_context)

    async with aiohttp.ClientSession(timeout=timeout, connector=connector) as session:
        tasks = [process_batch(session, b, semaphore) for b in batches]

        # 3. Process with tqdm progress bar
        for task in tqdm(asyncio.as_completed(tasks), total=len(tasks), desc="Embedding"):
            results = await task
            if results:
                # 4. Save progress immediately to file
                with open(OUTPUT_FILE, "a") as f:
                    for text, emb in results:
                        f.write(json.dumps({"text": text, "embedding": emb}) + "\n")

    # 5. Create final DataFrame
    final_data = []
    with open(OUTPUT_FILE, "r") as f:
        for line in f:
            try:
                final_data.append(json.loads(line))
            except Exception:
                # skip malformed lines that may have been written during failures
                continue

    return pd.DataFrame(final_data)

